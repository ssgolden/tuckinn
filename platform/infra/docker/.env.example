# ============================================================
# Tuckinn Docker Deployment - Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# For production: use .env.production (referenced by docker-compose.prod.yml)
# For development: use .env (referenced by docker-compose.dev.yml)
# ============================================================

# ----- Domain Configuration -----
STORE_DOMAIN=tuckinn.com
ADMIN_DOMAIN=admin.tuckinn.com
STAFF_DOMAIN=staff.tuckinn.com
API_DOMAIN=api.tuckinn.com

# ----- PostgreSQL -----
POSTGRES_DB=tuckinn_platform
POSTGRES_USER=tuckinn
POSTGRES_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql://tuckinn:change-me-to-a-strong-password@postgres:5432/tuckinn_platform?schema=public
# Local dev override (host-mapped port):
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_URL=redis://redis:6379
# Local dev override (host-mapped port):
REDIS_PORT=6379

# ----- Logging -----
LOG_LEVEL=info

# ----- Mailpit (dev only) -----
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# ----- Authentication -----
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-strong-random-secret
SESSION_SECRET=replace-with-strong-random-secret

# ----- Seed Data -----
SEED_ADMIN_EMAIL=admin@tuckinn.com
SEED_ADMIN_PASSWORD=replace-with-strong-password

# ----- Stripe -----
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me

# ----- AWS S3 -----
AWS_REGION=eu-west-1
S3_BUCKET=tuckinn-assets
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# ----- CORS -----
ALLOWED_ORIGINS=https://tuckinn.com,https://admin.tuckinn.com,https://staff.tuckinn.com