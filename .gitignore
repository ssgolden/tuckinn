node_modules/
package-lock.json
*.log

# Secrets — NEVER commit .env files
.env
.env.local
.env.production
.env.*
!.env.example
!.env.production.example
!.env.*.local
**/.env
**/.env.local
**/.env.production
**/.env.*.local

# Databases — runtime data, not source
*.sqlite
*.db
*.sqlite3

# Backups — use git/VPS snapshots instead
backup/
backup_*/
deployment_package/
deployment_package_*/

# Build artifacts
platform/.turbo/
platform/apps/mobile/.expo/
platform/apps/storefront/tsconfig.tsbuildinfo
platform/apps/api/src/generated/

# Temp files
tmp-*.png
tmp-*

# Credentials — no plain-text secrets
*.pem
*.key
login.txt
credentials.*

# Platform specific
platform/apps/api/src/generated/
platform/.next/
.next/
platform/apps/*/node_modules/
platform/runtime-logs/
platform/test-results/
platform/tmp-*.png

# Root legacy files (keep as reference, but don't track build artifacts)
/database.sqlite
/backend/
